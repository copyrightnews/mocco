# ─────────────────────────────────────────────────────────────────────
# Mocco Bot — Environment Variables
# ─────────────────────────────────────────────────────────────────────
# [REQ] = REQUIRED (bot cannot start without it)
# [OPT] = OPTIONAL (bot starts; the related feature is disabled if missing)
# ─────────────────────────────────────────────────────────────────────

# [REQ] Telegram — get from @BotFather
TELEGRAM_TOKEN=

# [REQ] PostgreSQL connection string.
# Railway: New → Database → PostgreSQL → "DATABASE_URL" copy from Variables tab.
DATABASE_URL=postgresql://user:password@localhost:5432/mocco


# ── LLM / Provider keys ─────────────────────────────────────────────
# All optional — the bot will run, but if you don't set them, users
# MUST /connect their own keys to use the corresponding features.

# [OPT] OpenRouter fallback key. Used when a user has no own key connected.
# Get one: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# [OPT] Serper (Google web search) — https://serper.dev
SERPER_API_KEY=

# [OPT] ENCRYPTION_KEY — REQUIRED for /connect to work (user key storage).
# Without this, /connect is disabled and users cannot save their own keys.
# Generate with:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# KEEP THIS SECRET. If you lose it, all stored user keys become unrecoverable.
ENCRYPTION_KEY=


# ── Behavior ────────────────────────────────────────────────────────
# Default model used when a user hasn't picked one via /model.
CHAT_MODEL=minimax/minimax-m2.5:free

# Logging
LOG_LEVEL=INFO


# ── Admin (recommended) ─────────────────────────────────────────────
# Your own Telegram user ID. Get it from @userinfobot.
OWNER_ID=
# The bot's own numeric ID. Optional; used by /blacklist to prevent self-lockout.
BOT_ID=
